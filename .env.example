# Copie este arquivo para .env e ajuste os valores.

# Chave secreta usada para assinar a sessão. OBRIGATÓRIA em produção.
# Gere uma chave forte, por exemplo:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-por-uma-aleatoria

# URL de conexão do banco de dados.
# Padrão: SQLite (arquivo backend/mytrees.db). Para produção use, por exemplo:
#   DATABASE_URL=postgresql+psycopg://usuario:senha@host:5432/mytrees
DATABASE_URL=sqlite:///mytrees.db

# Debug do Flask: 0 em produção, 1 em desenvolvimento.
FLASK_DEBUG=0

# Cookies de sessão apenas via HTTPS. Mantenha 0 em desenvolvimento local
# (http://localhost) e use 1 em produção atrás de HTTPS.
SESSION_COOKIE_SECURE=0
